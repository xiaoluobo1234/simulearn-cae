# ===========================================
# SimuLearn CAE - Environment Configuration
# Copy to .env and fill in your values
# ===========================================

# Database
DATABASE_URL=postgresql+asyncpg://simulearn:YOUR_DB_PASSWORD@postgres:5432/simulearn_cae

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# MinIO (S3-compatible)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=YOUR_MINIO_USER
MINIO_SECRET_KEY=YOUR_MINIO_PASSWORD
MINIO_BUCKET=simulearn-cae

# OpenAI (for Phase 2 AI agent)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# CAE
SIMULATION_TIMEOUT=300
